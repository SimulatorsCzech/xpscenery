{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch xpscenery-cli (Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-msvc/cli/Debug/xpscenery-cli.exe",
      "args": ["--version"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "preLaunchTask": "CMake: build"
    },
    {
      "name": "Launch xpscenery UI (Debug)",
      "type": "cppvsdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/windows-msvc-ui/ui/Debug/xpscenery.exe",
      "args": [],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "environment": [
        { "name": "QT_QPA_PLATFORM", "value": "windows" },
        { "name": "QT_LOGGING_RULES", "value": "qt.qml.debug=true" }
      ]
    },
    {
      "name": "Attach to running process",
      "type": "cppvsdbg",
      "request": "attach",
      "processId": "${command:pickProcess}"
    }
  ]
}
