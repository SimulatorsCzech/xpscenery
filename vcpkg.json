{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "xpscenery",
  "version-semver": "0.1.0-alpha.0",
  "description": "Modern Windows GIS + scenery authoring tool for X-Plane 12",
  "homepage": "https://github.com/YOUR_USERNAME/xpscenery",
  "license": "MIT",
  "supports": "windows & !arm",
  "dependencies": [
    {
      "name": "boost-graph",
      "version>=": "1.88.0"
    },
    {
      "name": "boost-geometry",
      "version>=": "1.88.0"
    },
    {
      "name": "boost-polygon",
      "version>=": "1.88.0"
    },
    {
      "name": "boost-filesystem",
      "version>=": "1.88.0"
    },
    {
      "name": "boost-program-options",
      "version>=": "1.88.0"
    },
    {
      "name": "cgal",
      "version>=": "6.0"
    },
    {
      "name": "gdal",
      "version>=": "3.11.0",
      "features": ["tools"]
    },
    {
      "name": "gmp",
      "version>=": "6.3.0"
    },
    {
      "name": "mpfr",
      "version>=": "4.2.1"
    },
    {
      "name": "fmt",
      "version>=": "11.0.0"
    },
    {
      "name": "spdlog",
      "version>=": "1.15.0"
    },
    {
      "name": "nlohmann-json",
      "version>=": "3.12.0"
    },
    {
      "name": "tinyxml2",
      "version>=": "11.0.0"
    },
    {
      "name": "zlib",
      "version>=": "1.3.1"
    },
    {
      "name": "catch2",
      "version>=": "3.8.0"
    }
  ],
  "features": {
    "ui": {
      "description": "Build Qt 6 desktop application",
      "dependencies": [
        {
          "name": "qtbase",
          "version>=": "6.9.0",
          "features": ["gui", "widgets", "concurrent"]
        },
        {
          "name": "qtdeclarative",
          "version>=": "6.9.0"
        },
        {
          "name": "qtquick3d",
          "version>=": "6.9.0"
        },
        {
          "name": "qtlocation",
          "version>=": "6.9.0"
        },
        {
          "name": "qttools",
          "version>=": "6.9.0"
        },
        {
          "name": "qtshadertools",
          "version>=": "6.9.0"
        }
      ]
    },
    "tests": {
      "description": "Build unit tests and regression suite",
      "dependencies": []
    }
  }
}
