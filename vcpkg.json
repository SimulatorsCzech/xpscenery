{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "xpscenery",
  "version-semver": "0.1.0-alpha.0",
  "description": "Modern Windows GIS + scenery authoring tool for X-Plane 12",
  "homepage": "https://github.com/SimulatorsCzech/xpscenery",
  "license": "MIT",
  "supports": "windows & !arm",
  "builtin-baseline": "5e6578b62d9e4ac5a563e816802a56818540cd2e",

  "dependencies": [
    "fmt",
    "spdlog",
    "nlohmann-json",
    "cli11",
    "catch2"
  ],

  "features": {
    "full": {
      "description": "Full build with all geometry/GIS dependencies (Phase 1+)",
      "dependencies": [
        { "name": "boost-graph"        },
        { "name": "boost-geometry"     },
        { "name": "boost-polygon"      },
        { "name": "boost-filesystem"   },
        { "name": "boost-program-options" },
        { "name": "cgal"               },
        { "name": "gdal", "features": ["tools"] },
        { "name": "gmp"                },
        { "name": "mpfr"               },
        { "name": "tinyxml2"           },
        { "name": "zlib"               }
      ]
    },
    "ui": {
      "description": "Build Qt 6 desktop application (Phase 2+)",
      "dependencies": [
        { "name": "qtbase",       "features": ["gui", "widgets", "concurrent"] },
        { "name": "qtdeclarative" },
        { "name": "qtquick3d"    },
        { "name": "qtlocation"   },
        { "name": "qttools"      },
        { "name": "qtshadertools" }
      ]
    }
  }
}
